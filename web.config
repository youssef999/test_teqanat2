<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Static content + MIME types -->
    <staticContent>
      <!-- image/jpeg (Flutter web /uploads proxy) -->
      <remove fileExtension=".jpg" />
      <mimeMap fileExtension=".jpg" mimeType="image/jpeg" />
      <remove fileExtension=".jpeg" />
      <mimeMap fileExtension=".jpeg" mimeType="image/jpeg" />
      <remove fileExtension=".png" />
      <mimeMap fileExtension=".png" mimeType="image/png" />

      <!-- webp -->
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />

      <!-- Flutter Web -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />

      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />

      <remove fileExtension=".map" />
      <mimeMap fileExtension=".map" mimeType="application/octet-stream" />

      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <!-- Gzip/Brotli for static + dynamic responses (no payload cost, faster transfer) -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- SPA rewrite for Flutter (exclude /api — handled by reverse proxy when enabled) -->
    <rewrite>
      <rules>
        <!-- Permanent redirect: root → default locale (SEO; matches index.html JS fallback) -->
        <rule name="Root to Arabic" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="/ar" redirectType="Permanent" />
        </rule>
        <rule name="API Reverse Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="https://apis.teqanat.com/api/{R:1}" />
        </rule>
        <rule name="Uploads Reverse Proxy" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <action type="Rewrite" url="https://apis.teqanat.com/uploads/{R:1}" />
        </rule>
        <rule name="AR Uploads Reverse Proxy" stopProcessing="true">
          <match url="^ar/uploads/(.*)" />
          <action type="Rewrite" url="https://apis.teqanat.com/uploads/{R:1}" />
        </rule>
        <rule name="EN Uploads Reverse Proxy" stopProcessing="true">
          <match url="^en/uploads/(.*)" />
          <action type="Rewrite" url="https://apis.teqanat.com/uploads/{R:1}" />
        </rule>
        <rule name="Flutter SPA Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/api/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/uploads/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/ar/uploads/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/en/uploads/" negate="true" />
            <!-- لو الطلب ملف موجود سيبه -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- لو الطلب فولدر موجود سيبه -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>

  <!-- Long cache ONLY for immutable, versioned asset folders. Code files
       (index.html, main.dart.js, *_service_worker.js, version.json) are left
       uncached so deploys appear immediately. -->
  <location path="canvaskit">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="assets">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="icons">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

</configuration>
